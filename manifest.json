{
  "manifest_version": 3,
  "name": "Chess Real-Time Analyzer",
  "version": "1.0.0",
  "description": "Real-time Stockfish-powered move suggestions that run locally on your device for Chess.com.",
  "minimum_chrome_version": "116",
  "permissions": [
    "activeTab",
    "storage",
    "offscreen",
    "tabs"
  ],
  "host_permissions": [
    "https://www.chess.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.chess.com/game/*",
        "https://www.chess.com/play/*",
        "https://www.chess.com/live/*"
      ],
      "js": [
        "chess.js",
        "content.js"
      ],
      "css": [
        "overlay.css"
      ],
      "run_at": "document_end"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "stockfish.js",
        "offscreen.html",
        "offscreen.js"
      ],
      "matches": [
        "https://www.chess.com/*"
      ]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}